# Phone Home — Environment Configuration

# HTTPS port (camera/mic require secure context)
PORT=3900

# HTTP port for local API access
HTTP_PORT=3902

# Telegram alerts (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Python binary for YOLO detection (default: ./venv/bin/python)
# PYTHON_BIN=/usr/bin/python3

# Ollama endpoint for LLaVA vision analysis
# OLLAMA_URL=http://localhost:11434
